# ============================================================
# Inventory & Order Management System - Environment Variables
# Copy this file to .env and fill in the values before running.
# ============================================================

# ---------- Database ----------
POSTGRES_USER=ioms_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=ioms
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---------- Backend ----------
# Full DB URL used by SQLAlchemy / Alembic. Override in production.
DATABASE_URL=postgresql+psycopg2://ioms_user:change_me_in_production@db:5432/ioms

# JWT - generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=please_generate_a_strong_random_secret_for_production_use
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS - comma separated list of allowed origins
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# App
APP_ENV=development
APP_NAME=Inventory & Order Management System
LOW_STOCK_THRESHOLD=10

# ---------- Frontend ----------
# Used at build time by Vite. Must be prefixed with VITE_.
VITE_API_BASE_URL=http://localhost:8000/api/v1
